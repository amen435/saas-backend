# Database — must be a real host (NOT the word "host"). Local example:
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/your_db_name
DATABASE_URL=postgresql://postgres:password@localhost:5432/saas

# JWT/session (same secret must be used for every sign + verify; rotate = everyone re-logs in)
JWT_SECRET=replace-with-a-random-64-character-secret
JWT_EXPIRY=1d
# Production (HTTPS): None or unset so Vercel→Render cookies work. Local + Vite /api proxy only: can use Lax.
COOKIE_SAME_SITE=None
# If browsers block third-party cookies, login also returns accessToken for Authorization: Bearer (XSS risk vs cookies).
ACCESS_TOKEN_IN_BODY=true

# Server
PORT=5000
HOST=0.0.0.0
NODE_ENV=development
APP_BASE_URL=http://localhost:5000

# Frontend origins allowed by CORS (comma-separated). Localhost + saas-alpha-gold.vercel.app are
# in server defaults; still set this for previews/custom domains, e.g.:
# FRONTEND_URL=https://saas-alpha-gold.vercel.app,https://your-custom-domain.com
# Cross-origin cookies (Vercel → Render): use None in production (defaults to None if unset):
# COOKIE_SAME_SITE=None
# Allow https://*.vercel.app (default true). Set to false for strict allowlist only:
# CORS_ALLOW_VERCEL_PREVIEW=false
FRONTEND_URL=http://localhost:8080,http://127.0.0.1:8080
CORS_ALLOW_VERCEL_PREVIEW=true

# AI Configuration
GEMINI_API_KEY=replace-with-real-api-key
AI_MODEL=gemini-2.5-flash
AI_MAX_TOKENS=2048
AI_TEMPERATURE=0.7
AI_RATE_LIMIT_PER_MINUTE=10
